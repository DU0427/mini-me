{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist-electron",
    "sourceMap": true,
    "lib": ["ESNext"]
  },
  "include": ["src/main/**/*.ts", "vite.config.ts"]
}
